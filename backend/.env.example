# ─── Base de données ────────────────────────────────────────────────────────
# Chaîne de connexion PostgreSQL utilisée par Prisma.
DATABASE_URL="postgresql://voidcolony:changeme@localhost:5432/voidcolony?schema=public"

# ─── Serveur ─────────────────────────────────────────────────────────────────
PORT=3000

# Secret de signature des JWT (auth HTTP + Socket.io). Générez une valeur
# aléatoire forte en production, par exemple : openssl rand -hex 32
JWT_SECRET=dev_secret_please_change

# ─── Envoi d'email (SMTP) ────────────────────────────────────────────────────
# Utilisé pour l'envoi du nonce de vérification à l'inscription.
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@thomasbaert.fr
SMTP_PASS=changeme
