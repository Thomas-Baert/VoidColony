# ─── API & Temps réel ────────────────────────────────────────────────────────
# En développement, le proxy Vite redirige déjà /api et /socket.io vers le
# backend (voir frontend/vite.config.ts) : ces variables peuvent rester vides.
# Renseignez-les explicitement pour un build de production servi séparément
# du backend (ex: domaine ou port différent).

VITE_API_URL=/api
VITE_SOCKET_URL=/

